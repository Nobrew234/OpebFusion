{
  "version": 1,
  "server": { "port": 4001 },
  "auth": { "apiKeys": [ { "id": "local-dev", "tokenEnv": "OPEN_FUSION_FIXTURE_TOKEN", "allowedRoutes": ["default"] } ] },
