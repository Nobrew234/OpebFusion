{
  "version": 1,
  "server": { "port": 4001 },
  "auth": { "apiKeys": [ { "id": "local-dev", "tokenEnv": "OPEN_FUSION_FIXTURE_TOKEN", "allowedRoutes": ["default"] } ] },
  "providers": { "openrouter": { "type": "openrouter", "apiKeyEnv": "OPENROUTER_API_KEY" } },
  "models": {
    "orchestrator.default": { "provider": "openrouter", "model": "openai/gpt-4.1", "role": "orchestrator" },
    "worker.fast": { "provider": "openrouter", "model": "openai/gpt-4.1-mini", "role": "delegate" }
  },
  "routes": {
    "default": {
      "publicModel": "open-fusion/default",
      "orchestrator": "orchestrator.default",
      "allowedDelegateModels": ["worker.fast"],
      "maxDelegations": 3,
      "maxDepth": 2
    }
  }
}
